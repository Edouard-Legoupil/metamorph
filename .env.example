# PostgreSQL
POSTGRES_DB=metamorph
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Redis
REDIS_URL=redis://redis:6379/0

# Backend
SECRET_KEY=super-secret-key

# Frontend
VITE_BACKEND_URL=http://localhost:8000
VITE_WIKIJS_URL=http://wikijs:3000

# Wiki.js
WIKIJS_API_KEY=wikijs-key
WIKIJS_ADMIN_PASSWORD=changeme

# LiteLLM
LITELLM_PROXY_URL=http://litellm:4000
LITELLM_MODEL_PREFERENCE=gpt-4,claude-3,ollama/llama3
OPENAI_API_KEY=sk-openai
ANTHROPIC_API_KEY=sk-anthropic
OLLAMA_BASE_URL=http://ollama:11434

# MinIO (S3 compatible)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=metamorph-documents
STORAGE_PROVIDER=s3

# Static NGINX settings can go in ./infra/nginx/nginx.conf
