# Staging environment configuration for Metamorph

# Database configuration
POSTGRES_DB=metamorph_staging
POSTGRES_USER=metamorph_user
POSTGRES_PASSWORD=staging_password_change_me
DATABASE_URL=postgresql+psycopg2://metamorph_user:staging_password_change_me@postgres:5432/metamorph_staging

# Redis configuration
REDIS_URL=redis://redis:6379/0

# Security settings
SECRET_KEY=staging_secret_key_with_32_plus_characters
MCP_API_KEYS=staging_api_key_1,staging_api_key_2

# CORS settings - more permissive for staging
ALLOWED_ORIGINS=https://staging.metamorph.example.com,http://localhost:3000

# File storage (MinIO/S3)
S3_ACCESS_KEY=minio_admin
S3_SECRET_KEY=minio_password
S3_BUCKET=metamorph-staging
STORAGE_PROVIDER=s3

# External services
WIKIJS_API_KEY=wikijs_staging_key
LITELLM_PROXY_URL=http://litellm:4000

# Rate limiting - less restrictive for staging
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=100

# File upload limits
MAX_FILE_SIZE=52428800  # 50MB
MAX_PREVIEW_LENGTH=10000

# Logging - more verbose for staging
LOG_LEVEL=DEBUG
LOG_FILE=/var/log/metamorph/staging.log

# Monitoring and tracing
PROMETHEUS_ENABLED=true
OPENTELEMETRY_ENABLED=true
OPENTELEMETRY_ENDPOINT=http://jaeger:4318/v1/traces

# Feature flags
MAINTENANCE_MODE=false
READ_ONLY_MODE=false
DEBUG_MODE=true

# External service timeouts
EXTERNAL_SERVICE_TIMEOUT=60

# Health checks
HEALTH_CHECK_INTERVAL=30
