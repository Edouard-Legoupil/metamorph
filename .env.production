# Production environment configuration for Metamorph
# This file should be secured and not committed to version control in real deployments

# Database configuration
POSTGRES_DB=metamorph_prod
POSTGRES_USER=metamorph_user
POSTGRES_PASSWORD=secure_password_change_me
DATABASE_URL=postgresql+psycopg2://metamorph_user:secure_password_change_me@postgres:5432/metamorph_prod

# Redis configuration
REDIS_URL=redis://redis:6379/0

# Security settings
SECRET_KEY=generate_strong_secret_key_here_with_32_plus_characters
MCP_API_KEYS=api_key_1,api_key_2,api_key_3

# CORS settings
ALLOWED_ORIGINS=https://metamorph.example.com,https://www.metamorph.example.com

# File storage (MinIO/S3)
S3_ACCESS_KEY=minio_admin
S3_SECRET_KEY=minio_password
S3_BUCKET=metamorph-prod
STORAGE_PROVIDER=s3

# External services
WIKIJS_API_KEY=wikijs_api_key_here
LITELLM_PROXY_URL=http://litellm:4000

# Rate limiting
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_BURST=50

# File upload limits
MAX_FILE_SIZE=52428800  # 50MB
MAX_PREVIEW_LENGTH=5000

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/metamorph/app.log

# Monitoring and tracing
PROMETHEUS_ENABLED=true
OPENTELEMETRY_ENABLED=true
OPENTELEMETRY_ENDPOINT=http://jaeger:4318/v1/traces

# Feature flags
MAINTENANCE_MODE=false
READ_ONLY_MODE=false
DEBUG_MODE=false

# External service timeouts
EXTERNAL_SERVICE_TIMEOUT=30

# Health checks
HEALTH_CHECK_INTERVAL=60
